  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.0",
    "@testing-library/user-event": "14.6.1",
    "@types/react": "19.2.0",
    "@types/react-dom": "19.2.0",
    "@vitejs/plugin-react-swc": "4.3.1",
    "@vitest/coverage-v8": "4.1.8",
    "@vitest/ui": "4.1.8",
    "jsdom": "26.0.0",
    "typescript": "5.7.3",
    "vite": "8.0.16",
    "vitest": "4.1.8"
  }
