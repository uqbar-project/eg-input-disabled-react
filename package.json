{
  "name": "eg-input-disabled-react",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "dev": "vite",
